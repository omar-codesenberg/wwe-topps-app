rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    match /events/{eventId} {
      allow read: if request.auth != null;
      // Admin writes go through callables (createEventWithSlots, etc.) which use
      // the admin SDK and bypass these rules; client-side writes require the claim.
      allow write: if isAdmin();
      match /slots/{slotId} {
        allow read: if request.auth != null;
        allow write: if isAdmin();
      }
    }
    match /users/{userId} {
      // Split get from list: get is per-doc (self or admin), list is admin-only.
      // Collection list queries can be rejected by Firestore's rule engine even when
      // isAdmin() is OR'd in, because the other branch depends on the {userId} path
      // variable — splitting makes the admin intent explicit.
      allow get: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();
      allow write: if request.auth != null && request.auth.uid == userId;
      // legacyUser flips happen via setUserLegacy callable (admin SDK bypasses rules).
    }
    match /purchases/{purchaseId} {
      // Split get from list (same reasoning as /users): the per-doc branch
      // reads resource.data.userId which Firestore can only statically prove
      // when the query itself constrains userId. Admin listings by eventId
      // don't carry that constraint, so we make the admin intent explicit.
      allow get: if request.auth != null
                 && (request.auth.uid == resource.data.userId || isAdmin());
      allow list: if isAdmin()
                  || (request.auth != null
                      && request.query.limit <= 1000
                      && resource.data.userId == request.auth.uid);
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
    }
  }
}
