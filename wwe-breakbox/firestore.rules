rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    match /events/{eventId} {
      allow read: if request.auth != null;
      // Admin writes go through callables (createEventWithSlots, etc.) which use
      // the admin SDK and bypass these rules; client-side writes require the claim.
      allow write: if isAdmin();
      match /slots/{slotId} {
        allow read: if request.auth != null;
        allow write: if isAdmin();
      }
    }
    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow write: if request.auth != null && request.auth.uid == userId;
      // legacyUser flips happen via setUserLegacy callable (admin SDK bypasses rules).
    }
    match /purchases/{purchaseId} {
      allow read: if request.auth != null
                  && (request.auth.uid == resource.data.userId || isAdmin());
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
    }
  }
}
